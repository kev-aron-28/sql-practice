-- 1 Obtener todos los clientes ordenados por nombre.
SELECT * FROM CUSTOMERS ORDER BY NAME;
-- 2 Obtener todos los productos de la categoría “Electrónica”.
SELECT * FROM PRODUCTS WHERE CATEGORY = 'Electrónica';

-- 3 Obtener los pedidos realizados por el cliente con id = 1.
SELECT * FROM ORDERS WHERE CUSTOMER_ID = 1;

-- 4 Obtener los pedidos con el nombre del cliente.
SELECT C.NAME, O.ID FROM ORDERS O INNER JOIN CUSTOMERS C
ON O.CUSTOMER_ID = C.ID;

-- 5 Obtener todos los ítems de pedido con nombre de producto y precio.
SELECT * FROM ORDER_ITEMS O INNER JOIN PRODUCTS P
ON O.PRODUCT_ID = P.ID;

-- 6 Listar los pedidos con su total (sumando precio * cantidad).
SELECT O.ORDER_ID, O.QUANTITY, P.PRICE, O.QUANTITY * PRICE AS TOTAL FROM ORDER_ITEMS O INNER JOIN PRODUCTS P
ON O.PRODUCT_ID = P.ID;

-- 7 Obtener cuántos pedidos ha hecho cada cliente.
SELECT CUSTOMER_ID, COUNT(*) FROM ORDERS O
GROUP BY CUSTOMER_ID;

-- 8 Total gastado por cada cliente.
SELECT 
 C.NAME, 
 SUM(QUANTITY * PRICE)
FROM ORDER_ITEMS O INNER JOIN 
ORDERS R ON O.ORDER_ID = R.ID
INNER JOIN CUSTOMERS C ON 
R.CUSTOMER_ID = C.ID
INNER JOIN PRODUCTS P ON
O.PRODUCT_ID = P.ID
GROUP BY C.NAME
;


